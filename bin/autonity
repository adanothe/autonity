#!/bin/bash

AUT=$(which aut)
VALIDATORADDRESS=$(grep 'validator=' $HOME/.autrc | cut -d'=' -f2)
KEFILE1="$HOME/.autonity/keystore/oracle.key"
KEFILE2="$HOME/.autonity/keystore/treasury.key"
TOOLS="$HOME/autonity/tools"
AUTONITY=$(which autonity)
CAX="$TOOLS/cax"


display_help() {
    cat << EOF
Usage: autonity <command> <subcommand>

Available commands:
  validator           - Command for interacting with Validator management
  wallet              - Command for interacting with Wallet management
  node                - Command for interacting with Node management
  oracle              - Command for interacting with Oracle server management
  cax                 - Command for interacting with CAX
  help                - Display help menu

EOF
    exit 0
}


[[ $# -eq 0 ]] && display_help && exit 1


case "$1" in
    validator)
        case "$2" in
            setup)
                while true; do
                    clear
                    echo "===== Validator Management Menu ====="
                    options=("Create Validator" "Bond & Unbond Validator" "Pause & Reactivate Validator" "Change Commission Rate" "Exit")
                    PS3="Enter your choice (1-${#options[@]}): "
                    select opt in "${options[@]}"; do
                        case $REPLY in
                            1) $TOOLS/create-validator.sh ;;
                            2) $TOOLS/bond-unbond-validator.sh ;;
                            3) $TOOLS/pause-reactivate-validator.sh ;;
                            4) $TOOLS/change-validator-commission.sh ;;
                            5) echo "Exiting..." && exit 0 ;;
                            *) echo "Invalid choice. Please enter a number between 1-5." ;;
                        esac
                        break
                    done
                    read -p "Press Enter to continue..."
                done
                ;;
            info) echo "Validator Info" && $TOOLS/validatorinfo.sh ;;
            list) echo "Validator List" && $AUT validator list | awk '{print NR".",$0}' ;;
            seat) [[ "$3" == "active" ]] && echo "Seat Active Validators List" && $TOOLS/committe.sh ;;
            committe) 
                echo "Check if your validator is in the Seat Active"
                $AUT protocol get-committee | grep $VALIDATORADDRESS && echo "Your validator is in the committee" || echo "Your validator is not in the committee"
                ;;
            help|*) $AUTONITY validator help ;;
        esac
        ;;
    wallet)
        case "$2" in
            management)
                while true; do
                    clear
                    echo "===== Wallet Management Menu ====="
                    options=("Create Signature registration for game" "Create Signature for Validator onboarded" "Create transaction" "Create wallet" "Create backup wallet" "Exit")
                    PS3="Enter your choice (1-${#options[@]}): "
                    select opt in "${options[@]}"; do
                        case $REPLY in
                            1) $TOOLS/signature.sh ;;
                            2) $TOOLS/valonboarded.sh ;;
                            3) $TOOLS/tx.sh ;;
                            4) $TOOLS/create-other-wallet.sh ;;
                            5) $TOOLS/backup-wallet.sh ;;
                            6) echo "Exiting..." && exit 0 ;;
                            *) echo "Invalid choice. Please enter a number between 1-6." ;;
                        esac
                        break
                    done
                    read -p "Press Enter to continue..."
                done
                ;;
            info) echo "Wallet Info" && $TOOLS/wallet-info.sh ;;
            list) echo "Wallet List" && $AUT account list ;;
            help|*) $AUTONITY wallet help ;;
        esac
        ;;
    node)
        case "$2" in
            start) echo "Start Node" && docker-compose -f ~/autonity/docker-compose.yml up -d autonity ;;
            logs) echo "Node Logs" && docker logs -f --tail=20 autonity ;;
            epoch) echo "Node Epoch" && $TOOLS/epoch.sh ;;
            sync) echo "Node Sync" && $AUT node info | jq '{eth_blockNumber, eth_syncing}' ;;
            update) 
                echo "Node Update"
                docker-compose -f $HOME/autonity/docker-compose.yml pull autonity
                docker-compose -f $HOME/autonity/docker-compose.yml up -d autonity
                ;;
            stop) echo "Stop Node" && docker stop autonity ;;
            restart) echo "Restart Node" && docker restart autonity ;;
            help|*) $AUTONITY node help ;;
        esac
        ;;
    oracle)
        case "$2" in
            start) echo "Start Oracle" && docker-compose -f ~/autonity/docker-compose.yml up -d oracle ;;
            logs) echo "Oracle Logs" && docker logs -f --tail=20 oracle ;;
            stop) echo "Stop Oracle" && docker stop oracle ;;
            restart) echo "Restart Oracle" && docker restart oracle ;;
            update) 
                echo "Oracle Update"
                docker-compose -f $HOME/autonity/docker-compose.yml pull oracle
                docker-compose -f $HOME/autonity/docker-compose.yml up -d oracle
                ;;
            help|*) $AUTONITY oracle help ;;
        esac
        ;;
    cax)
        case "$2" in
            menu)
                while true; do
                    clear
                    echo "===== CAX Management Menu ====="
                    options=("Create Api Key" "Check Balance" "Place Order" "Cancel Order" "Withdraw" "Exit")
                    PS3="Enter your choice (1-${#options[@]}): "
                    select opt in "${options[@]}"; do
                        case $REPLY in
                            1) $CAX/generate-api.sh ;;
                            2) $CAX/check-balance.sh ;;
                            3) $CAX/order.sh ;;
                            4) $CAX/cancel-order.sh ;;
                            5) $CAX/withdraw.sh ;;
                            6) echo "Exiting..." && exit 0 ;;
                            *) echo "Invalid choice. Please enter a number between 1-6." ;;
                        esac
                        break
                    done
                    read -p "Press Enter to continue..."
                done
                ;;
            help|*) $AUTONITY cax help ;;
        esac
        ;;
    help|*) display_help ;;
esac

exit 0
